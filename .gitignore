# ──────────────────────────────────────────────
# Root-level .gitignore for LCS School Treasury
# ──────────────────────────────────────────────

# Environment / secrets – NEVER commit these
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.egg
*.egg-info/
dist/
build/
.eggs/
*.so

# Django
db.sqlite3
db.sqlite3-journal
*.log
media/
staticfiles/
static_root/

# Virtual environments
venv/
env/
.venv/
.env/
ENV/

# Node / Frontend
node_modules/
frontend/dist/
frontend/dist-ssr/
*.local

# Logs
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor & OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
